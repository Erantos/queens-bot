{
  "name": "queens-bot",
  "version": "1.0.0",
  "description": "Queenstown's commands official parser",
  "homepage": "https://github.com/Erantos/queens-bot#readme",
  "bugs": {
    "url": "https://github.com/Erantos/queens-bot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Erantos/queens-bot.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "build:debug": "npm run clean && tsc --sourceMap",
    "start": "node --env-file=.env dist/index.js",
    "dev": "npm run build && npm run start",
    "test": "vitest",
    "deploy-cmd": "npm run build && node --env-file=.env dist/deploy.js"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "discord.js": "^14.26.0"
  }
}
